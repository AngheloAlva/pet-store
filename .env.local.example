# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit secrets.

# Neon Postgres connection string (pooled endpoint recommended for Next.js edge/serverless)
# Get it from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# HMAC-SHA256 signing secret for the demo persona session cookie.
# REQUIRED. Must be at least 32 random characters.
# Generate one with: openssl rand -base64 48
# The app fails to boot if this is missing or shorter than 32 chars.
SESSION_SECRET=replace-me-with-32-bytes-of-randomness-xxxxxxxxxxxxxxxx
